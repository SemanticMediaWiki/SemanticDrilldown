{
	"root": true,
	"extends": [
		"wikimedia/client/es2016",
		"wikimedia/jquery",
		"wikimedia/mediawiki"
	],
	"globals": {
		"mediaWiki": "readonly"
	},
	"rules": {
		"no-underscore-dangle": "off",
		"camelcase": "off",
		"array-callback-return": "warn",
		"no-jquery/no-parse-html-literal": "off",
		"no-jquery/no-global-selector": "off"
	}
}
