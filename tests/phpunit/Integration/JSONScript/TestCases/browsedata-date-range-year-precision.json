{
	"description": "Date range filter must include year-only and month-precision dates (PR #134)",
	"setup": [
		{
			"namespace": "SMW_NS_PROPERTY",
			"page": "PR134Date",
			"contents": "[[Has type::Date]]"
		},
		{
			"namespace": "NS_CATEGORY",
			"page": "PR134DateCat",
			"contents": "{{#drilldowninfo: filters=PR134Date (property=PR134Date)|display parameters=format=list}}"
		},
		{
			"page": "PR134YearOnly1900",
			"contents": "[[Category:PR134DateCat]]{{#set: PR134Date=1900}}"
		},
		{
			"page": "PR134FullDate19000615",
			"contents": "[[Category:PR134DateCat]]{{#set: PR134Date=1900-06-15}}"
		},
		{
			"page": "PR134OutsideRange19020101",
			"contents": "[[Category:PR134DateCat]]{{#set: PR134Date=1902-01-01}}"
		}
	],
	"tests": [
		{
			"type": "special",
			"about": "date range filter must include year-only precision dates (1900 within 1900-01-01..1900-12-31)",
			"special-page": {
				"page": "BrowseData",
				"query-parameters": "PR134DateCat",
				"request-parameters": {
					"_lower_PR134Date": "1900-01-01",
					"_upper_PR134Date": "1900-12-31"
				}
			},
			"assert-output": {
				"to-contain": [
					"PR134YearOnly1900",
					"PR134FullDate19000615"
				],
				"not-contain": [
					"PR134OutsideRange19020101"
				]
			}
		}
	],
	"settings": {
		"wgArticlePath": "/index.php/$1",
		"wgLang": "en"
	},
	"meta": {
		"version": "2",
		"is-incomplete": false,
		"debug": false
	}
}
